# =============================================================
# .gitignore — adicione na raiz do projeto
# =============================================================

# Arquivos de ambiente (NUNCA enviar para o repositório)
.env
*.env
!*.env.example      # mantém apenas os exemplos

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Django
staticfiles/
mediafiles/

# Node / React
node_modules/
build/
.npm

# Docker
.dockerignore

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Sistema
.DS_Store
Thumbs.db